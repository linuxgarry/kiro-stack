# ============================================
# Kiro Stack 配置文件
# ============================================

# -------------------- 管理面板 --------------------
# Web 管理面板密码（必填）
ADMIN_PASSWORD=change_this_password

# -------------------- 旧版 gateway 模式（可选） --------------------
# 默认 docker-compose 只运行 kiro-go 一个容器，不需要内部通信密钥。
# 只有你手动启用 kiro-go -> kiro-gateway 转发时才需要设置它。
# INTERNAL_API_KEY=change_this_api_key

# -------------------- 可选配置 --------------------
# 如果你单独运行旧版 kiro-gateway，可以配置它的出站代理
# VPN_PROXY_URL=http://127.0.0.1:7890
# VPN_PROXY_URL=socks5://127.0.0.1:1080

# 调试模式（可选）
# DEBUG_MODE=off        # 关闭（默认）
# DEBUG_MODE=errors     # 仅记录错误请求
# DEBUG_MODE=all        # 记录所有请求
